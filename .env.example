# Arbitrage Finder Configuration

# Rate limiting (requests per minute per marketplace)
RATE_LIMIT_RPM=30

# Database path
DB_PATH=./data/arbitrage.db

# Alert thresholds
MIN_MARGIN_PERCENT=15
MIN_CONFIDENCE=0.5

# Marketplace-specific fees (as decimals)
FEE_TRADERA=0.10
FEE_EBAY=0.13
FEE_BLOCKET=0.0

# Scraping settings
REQUEST_TIMEOUT_MS=10000
USER_AGENT=ArbitrageFinder/1.0 (educational project)
