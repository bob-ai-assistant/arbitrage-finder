{
  "name": "arbitrage-finder",
  "version": "1.0.0",
  "description": "Smart marketplace scanner for buy/sell arbitrage opportunities on Swedish and international marketplaces",
  "type": "module",
  "scripts": {
    "start": "tsx src/index.ts",
    "scan": "tsx src/index.ts scan",
    "watch": "tsx src/index.ts watch",
    "analyze": "tsx src/index.ts analyze",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "arbitrage",
    "marketplace",
    "scanner",
    "blocket",
    "tradera",
    "ebay"
  ],
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "chalk": "^5.6.2",
    "cheerio": "^1.2.0",
    "commander": "^14.0.3",
    "dotenv": "^17.3.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cheerio": "^0.22.35",
    "@types/node": "^25.5.0",
    "vitest": "^4.1.0"
  }
}
